# =============================================================================
# VILO - Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei als .env.local und trage deine Zugangsdaten ein:
#   cp .env.example .env.local
# =============================================================================

# --- Supabase (Datenbank + Realtime) ---
# Erforderlich fuer Online-Modus. Ohne diese Keys laeuft VILO im Offline-Modus (localStorage).
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...dein-anon-key

# --- OpenAI (Sprachbefehle via LLM) ---
# Optional. Ohne Key werden Sprachbefehle regelbasiert geparst.
VITE_OPENAI_API_KEY=sk-...dein-openai-key

